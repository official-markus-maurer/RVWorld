<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
        Width="700" Height="400"
        x:Class="ROMVault.Avalonia.Views.DirectoryMappingsWindow"
        Title="Set Directory Mapping"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Row 0: Rule Path -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Rule Path:" VerticalAlignment="Center"/>
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="2">
                <TextBlock Name="txtDATLocation" Text="label2"/>
            </Border>
        </Grid>

        <!-- Row 1: Dir Location and Buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Dir Location:" VerticalAlignment="Center"/>
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="2" Margin="0,0,5,0">
                <TextBlock Name="txtROMLocation" Text="label2"/>
            </Border>
            <Button Grid.Column="2" Name="btnSetROMLocation" Content="..." Width="35" Margin="0,0,5,0"/>
            <Button Grid.Column="3" Name="btnClearROMLocation" Content="X" Width="35"/>
        </Grid>

        <!-- Row 2: Apply/Delete Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Name="btnDelete" Content="Delete" Margin="0,0,10,0"/>
            <Button Name="btnSet" Content="Apply"/>
        </StackPanel>

        <!-- Row 3: Label for Grid -->
        <TextBlock Grid.Row="3" Text="Existing Mapping" FontWeight="Bold" Margin="0,0,0,5"/>

        <!-- Row 4: DataGrid -->
        <DataGrid Grid.Row="4" Name="DGDirectoryMappingRules" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Margin="0,0,0,10">
            <DataGrid.Styles>
                <Style Selector="DataGridRow">
                    <Setter Property="Background" Value="{Binding BgColor}"/>
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Rule Path" Binding="{Binding DirKey}" Width="*"/>
                <DataGridTextColumn Header="Dir Location" Binding="{Binding DirPath}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 5: Bottom Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Name="btnDeleteSelected" Content="Delete Selected" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Name="btnResetAll" Content="Reset All"/>
            <Button Grid.Column="3" Name="btnClose" Content="Done"/>
        </Grid>
    </Grid>
</Window>